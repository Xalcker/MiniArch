# Configuración de disco
DISK_DEVICE="/dev/sda"
ESP_SIZE="512M"
ROOT_SIZE="8G"
SWAP_SIZE="2G"

# Configuración del usuario kiosko
KIOSK_USER="kiosk"
# Cambia esta contraseña antes de ejecutar el instalador.
# Mantén las comillas para preservar literalmente espacios, #, $, &, etc.
KIOSK_PASSWORD="change-me"
# Solo para laboratorios/VMs desechables. Nunca lo actives en producción.
ALLOW_INSECURE_DEFAULT_PASSWORD="false"

# Configuración de Plymouth
PLYMOUTH_THEME_NAME="arch-kiosk"
PLYMOUTH_IMAGE_PATH="./assets/plymouth-image.png"

# Configuración del cursor
CURSOR_PATH="./assets/cursor/"

# Servicios remotos
ENABLE_SSH="true"

# Configuración regional y logs
TIMEZONE="America/Mexico_City"
LOG_FILE="/var/log/arch-kiosk-install.log"
