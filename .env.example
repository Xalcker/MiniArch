# Configuración del Instalador de Arch Linux - Modo Kiosko
# Copie este archivo a .env y ajuste los valores según sus necesidades

# ============================================================================
# CONFIGURACIÓN DEL DISCO
# ============================================================================

# Dispositivo de disco a utilizar (ADVERTENCIA: todos los datos serán destruidos)
DISK_DEVICE="/dev/sda"

# Tamaños de particiones
ESP_SIZE="512M"      # Partición EFI System (mínimo 512MB)
ROOT_SIZE="8G"       # Partición raíz del sistema
SWAP_SIZE="2G"       # Partición swap
# NOTA: La partición /home usará automáticamente el espacio restante

# ============================================================================
# CONFIGURACIÓN DEL USUARIO
# ============================================================================

# Nombre del usuario del sistema kiosko
KIOSK_USER="kiosk"

# Contraseña del usuario (CAMBIAR DESPUÉS DEL PRIMER INICIO)
KIOSK_PASSWORD="kiosk123"

# ============================================================================
# CONFIGURACIÓN DE PLYMOUTH (PANTALLA DE ARRANQUE)
# ============================================================================

# Nombre del tema personalizado de Plymouth
PLYMOUTH_THEME_NAME="arch-kiosk"

# Ruta a la imagen PNG para Plymouth (debe ser válida)
# Resolución recomendada: 1280x720 (se escalará automáticamente)
PLYMOUTH_IMAGE_PATH="./assets/plymouth-image.png"

# ============================================================================
# CONFIGURACIÓN DEL CURSOR
# ============================================================================

# Ruta al directorio del cursor personalizado
CURSOR_PATH="./assets/cursor/"

# ============================================================================
# CONFIGURACIÓN REGIONAL
# ============================================================================

# Zona horaria (formato: Continente/Ciudad)
# Ejemplos:
#   - America/Mexico_City
#   - America/New_York
#   - Europe/Madrid
#   - Asia/Tokyo
TIMEZONE="America/Mexico_City"

# Locale del sistema (descomentar y ajustar si es necesario)
# LOCALE="es_MX.UTF-8"

# ============================================================================
# CONFIGURACIÓN DE LOGS
# ============================================================================

# Archivo de log de la instalación
LOG_FILE="/var/log/arch-kiosk-install.log"

# ============================================================================
# CONFIGURACIÓN AVANZADA (OPCIONAL)
# ============================================================================

# Hostname del sistema
# HOSTNAME="arch-kiosk"

# Paquetes adicionales a instalar (separados por espacios)
# ADDITIONAL_PACKAGES="firefox vlc"

# Habilitar/deshabilitar Plymouth (yes/no)
# ENABLE_PLYMOUTH="yes"

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. Este archivo NO debe contener información sensible en producción
# 2. Cambie KIOSK_PASSWORD inmediatamente después de la instalación
# 3. Asegúrese de que DISK_DEVICE apunta al disco correcto
# 4. Verifique que la imagen de Plymouth existe en PLYMOUTH_IMAGE_PATH
# 5. El archivo .env NO debe ser versionado (está en .gitignore)
#
