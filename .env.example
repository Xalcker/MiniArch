# Configuracion de disco
DISK_DEVICE=/dev/sda
ESP_SIZE=512M
ROOT_SIZE=8G
SWAP_SIZE=2G

# Configuracion del usuario kiosko
KIOSK_USER=kiosk
# Cambia estas contrasenas antes de ejecutar el instalador.
KIOSK_PASSWORD=change-me
ROOT_PASSWORD=change-root
KIOSK_HOSTNAME=minikiosk
# Solo para laboratorios/VMs desechables. Nunca lo actives en produccion.
ALLOW_INSECURE_DEFAULT_PASSWORD=false

# Configuracion de Plymouth
ENABLE_PLYMOUTH=true
PLYMOUTH_THEME_NAME=arch-cage
PLYMOUTH_IMAGE_PATH=./assets/plymouth-image.png

# Configuracion del cursor
CURSOR_PATH=./assets/cursor/

# Servicios remotos y drivers
# Recomendado para Cage/YARG: false. Activalo solo si necesitas mantenimiento remoto.
ENABLE_SSH=false
INSTALL_NVIDIA=

# YARG / Cage
# stable usa YARG_URL; nightly consulta YARG_NIGHTLY_API_URL; ask pregunta al instalar.
YARG_RELEASE_CHANNEL=ask
YARG_URL=https://github.com/YARC-Official/YARG/releases/download/v0.14.0/YARG_v0.14.0-Linux-x86_64.zip
YARG_NIGHTLY_API_URL=https://api.github.com/repos/YARC-Official/YARG-BleedingEdge/releases/latest
YARG_NIGHTLY_ASSET_REGEX="linux.*(x86_64|x64|64).*\\.zip"
YARG_SONGS_DIR=/opt/YARG/Songs
YARG_PERSISTENT_DATA_DIR=/home/${KIOSK_USER}/.config/yarg-kiosk

# Configuracion regional y logs
TIMEZONE=America/Phoenix
LOG_FILE=/var/log/arch-cage-install.log
