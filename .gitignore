# ============================================================================
# LOGS Y ARCHIVOS TEMPORALES
# ============================================================================
*.log
/var/log/
*.tmp
*.swp
*.swo
*~
*.bak
*.backup

# ============================================================================
# ASSETS PERSONALIZADOS
# ============================================================================
# Los usuarios deben crear sus propios assets personalizados
# Los archivos de ejemplo y README se mantienen en el repositorio
assets/cursor/*
!assets/cursor/PLACEHOLDER.txt
!assets/cursor/README.md

# ============================================================================
# CONFIGURACIÓN LOCAL Y SENSIBLE
# ============================================================================
# Archivos de configuración con datos sensibles o específicos del entorno
.env
*.local
config.local.sh

# ============================================================================
# ARCHIVOS DE SISTEMA
# ============================================================================
.DS_Store
Thumbs.db
lost+found/
ehthumbs.db
Desktop.ini

